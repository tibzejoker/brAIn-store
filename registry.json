      "description": "Memory-domain nodes: KV store, vector store, intelligent gateway, autonomous consolidator, scheduled reminders."
    },
    "brAIn-tools": {
      "url": "https://github.com/tibzejoker/brAIn-tools",
      "clone": "https://github.com/tibzejoker/brAIn-tools.git",
      "default_branch": "main",
      "description": "Tool nodes: terminal, calc-py, http-bridge."
    },
    "brAIn-llm": {
      "url": "https://github.com/tibzejoker/brAIn-llm",
      "clone": "https://github.com/tibzejoker/brAIn-llm.git",
      "default_branch": "main",
      "description": "LLM-provider nodes: llm-basic (generic LLM caller), llm-cli (Claude/Codex/Gemini wrappers)."
    },
    "brAIn-ui": {
      "url": "https://github.com/tibzejoker/brAIn-ui",
      "clone": "https://github.com/tibzejoker/brAIn-ui.git",
      "default_branch": "main",
      "description": "UI nodes: chat (browser interface for human ↔ network)."
    },
    "brAIn-essentials": {
      "url": "https://github.com/tibzejoker/brAIn-essentials",
      "clone": "https://github.com/tibzejoker/brAIn-essentials.git",
      "default_branch": "main",
      "description": "Essentials: brain (consciousness), developer (meta), mcp-config + mcp-server (MCP federation), clock + cron + echo + attention."
    },
    "brAIn": {
      "url": "https://github.com/tibzejoker/brAIn",
      "clone": "https://github.com/tibzejoker/brAIn.git",
      "default_branch": "main",
      "description": "The brAIn framework itself — sdk, core, api, dashboard. No nodes; everything is in sister repos."
    },
    "brAIn-demo-loneliness": {
      "url": "https://github.com/tibzejoker/brAIn-demo-loneliness",
      "clone": "https://github.com/tibzejoker/brAIn-demo-loneliness.git",
      "default_branch": "main",
      "description": "Demo bundle — passive-aggressive phone (phone-loneliness): mobile sensor → bus → LLM → mobile TTS in one node."
    },
    "brAIn-bridges": {
      "url": "https://github.com/tibzejoker/brAIn-bridges",
      "clone": "https://github.com/tibzejoker/brAIn-bridges.git",
      "default_branch": "main",
      "description": "brAIn bridges — nodes mirroring chat.input / chat.response to/from external messengers (Telegram, WhatsApp, Discord, …)."
    },
    "brAIn-games": {
      "url": "https://github.com/tibzejoker/brAIn-games",
      "clone": "https://github.com/tibzejoker/brAIn-games.git",
      "default_branch": "main",
      "description": "brAIn games — LLM-driven game nodes (hangman, tictactoe, …) that play across every connected chat surface."
    }
  },
